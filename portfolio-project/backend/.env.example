# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me-required-for-docker
POSTGRES_DB=portfolio

# Security
# Required for docker-compose — must be at least 32 characters
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_EXPIRE_MINUTES=15
ADMIN_BOOTSTRAP_PASSWORD=
SEED_ADMIN_PASSWORD=

# GitHub Integration
GITHUB_USERNAME=TurkishKEBAB
GITHUB_API_TOKEN=
# Optional: Increases rate limit from 60 to 5000 requests/hour

# Email Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yigitokur@ieee.org
SMTP_PASSWORD=your-app-specific-password
# Generate app password: https://myaccount.google.com/apppasswords

# Redis Configuration
# For docker-compose: REDIS_URL is auto-set from REDIS_PASSWORD
REDIS_URL=redis://localhost:6379/0
# Required for docker-compose (sets requirepass on Redis server)
REDIS_PASSWORD=change-me-required-for-docker

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET_NAME=portfolio-files

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Production: https://yigitokur.vercel.app
CORS_EXTRA_ORIGINS=

# Environment
ENVIRONMENT=development
# Options: development, staging, production
# Production required: ENVIRONMENT=production

# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME=Yiğit Okur Portfolio API
VERSION=1.0.0
API_HOST=127.0.0.1
API_PORT=8000

# Rate Limiting
AUTH_LOGIN_RATE_LIMIT=5/minute
CONTACT_RATE_LIMIT=5/minute

# CAPTCHA (Turnstile/hCaptcha/reCAPTCHA)
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=
CAPTCHA_REQUIRED_PATHS=/api/v1/contact/
# Production required:
# CAPTCHA_ENABLED=true
# CAPTCHA_PROVIDER=turnstile
# CAPTCHA_SECRET_KEY=<set-secret>

# GitHub Cache
GITHUB_CACHE_HOURS=24

# File Upload
MAX_UPLOAD_SIZE=10485760
# 10MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Production required minimums:
# SECRET_KEY=<at-least-32-characters>
# FRONTEND_URL=https://<production-frontend-domain>
# DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<db>
